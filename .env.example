# ==========================================

# LuckyRay Environment Variables

# ==========================================

# NVIDIA AI

# Copy this file to .env and replace with your own values.

NVIDIA_API_KEY=

# Claude should research and select the most suitable model.

# Update this automatically during implementation.

NVIDIA_MODEL=

# ==========================================

# Application

# ==========================================

NODE_ENV=development

APP_NAME=LuckyRay

APP_VERSION=1.0.0

# ==========================================

# AI

# ==========================================

AI_PROVIDER=nvidia

AI_STREAMING=true

# ==========================================

# Logging

# ==========================================

LOG_LEVEL=info

# ==========================================

# Feature Flags

# ==========================================

ENABLE_DEBUG=false

ENABLE_EXPERIMENTAL=false
