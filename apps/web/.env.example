# LuckyRay Environment Variables
# Copy to .env.local and fill in values

# NVIDIA NIM API Key
# Get your key at: https://build.nvidia.com/
# Required for AI chat functionality
NVIDIA_API_KEY=your_nvidia_api_key_here

# Optional: Override the default AI model
# Default: meta/llama-3.1-70b-instruct
# NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Google Drive Sync (optional)
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Enable the Google Drive API and add your domain to Authorised JavaScript origins.
# Leave blank to disable the Google Drive Sync feature.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
